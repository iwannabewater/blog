{
  "name": "atelier-log",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "A bilingual editorial blog built with Astro, Tailwind CSS, React, and shadcn/ui.",
  "license": "MIT",
  "homepage": "https://iwannabewater.github.io/blog/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iwannabewater/blog.git"
  },
  "packageManager": "pnpm@11.0.8",
  "scripts": {
    "dev": "astro dev",
    "build": "rm -rf public/pagefind dist/pagefind && astro check && astro build && rm -rf dist/pagefind && pagefind --site dist && cp -r dist/pagefind public/",
    "preview": "astro preview",
    "sync": "astro sync",
    "astro": "astro",
    "clean": "rm -rf dist .astro public/pagefind",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "lint": "eslint ."
  },
  "dependencies": {
    "@astrojs/react": "^5.0.4",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "lodash.kebabcase": "^4.1.1",
    "lucide-react": "^1.14.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "remark-collapse": "^0.1.2",
    "remark-toc": "^9.0.0",
    "satori": "^0.26.0",
    "sharp": "^0.34.5",
    "simple-icons": "^16.18.1",
    "slugify": "^1.6.9",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@pagefind/default-ui": "^1.5.2",
    "@shikijs/transformers": "^4.0.2",
    "@tailwindcss/typography": "^0.5.19",
    "@types/lodash.kebabcase": "^4.1.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^9.39.2",
    "eslint-plugin-astro": "^1.7.0",
    "globals": "^17.6.0",
    "pagefind": "^1.5.2",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "shadcn": "^4.7.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  }
}
