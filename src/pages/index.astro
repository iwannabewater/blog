---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import ContentShowcase from "@/components/ContentShowcase.astro";
import FontRoleSystem from "@/components/FontRoleSystem.astro";
import ReadingActions from "@/components/react/ReadingActions";
import getSortedPosts from "@/utils/getSortedPosts";
import getUniqueTags from "@/utils/getUniqueTags";
import { withBase } from "@/utils/basePath";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const tags = getUniqueTags(posts);
const latestPost = sortedPosts[0];
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section
      id="hero"
      class="grid gap-10 py-12 sm:py-16 lg:grid-cols-[1.05fr_0.95fr] lg:items-center"
    >
      <div>
        <h1
          class="max-w-4xl font-display text-6xl leading-[1.05] font-medium text-balance text-foreground sm:text-7xl lg:text-8xl"
        >
          灯下有录，纸上有风。
        </h1>
        <p class="mt-6 max-w-2xl text-xl leading-9 text-muted-foreground">
          一处偏静的个人博客，写设计、代码、系统与日常判断。以暖纸为底，
          以墨蓝作记号，让文章像船过灯下，慢慢留下可以回看的波纹。
        </p>
        <div
          class="mt-8 inline-flex flex-col border-s-[7px] border-accent-ink ps-6"
          aria-label="Author signature"
        >
          <p
            class="font-heading text-4xl leading-none font-medium text-foreground sm:text-5xl"
          >
            Winston
          </p>
          <p
            class="font-role-quote mt-2 text-3xl leading-tight text-accent sm:text-4xl"
          >
            纸中留白，夜里成篇
          </p>
        </div>
        <p
          class="font-role-slogan slogan-mark -ms-1 mt-6 max-w-2xl text-6xl leading-none sm:text-7xl lg:text-8xl"
        >
          Larger than life
        </p>
        <div class="mt-8">
          <ReadingActions />
        </div>
      </div>

      <aside class="relative">
        <figure class="liuyun-scroll">
          <div class="liuyun-scroll-media">
            <img
              src={withBase("/paper-visual.svg")}
              alt="流云、栖木、小舟和灯影组成的纸面视觉标记"
              class="liuyun-scroll-image"
              loading="eager"
            />
          </div>
          <figcaption class="liuyun-scroll-caption">
            <span class="liuyun-scroll-hairline" aria-hidden="true"></span>
            <p>
              桨声灯影，
              <span>流云栖木。</span>
            </p>
          </figcaption>
        </figure>
        <div class="mt-5 grid grid-cols-3 gap-3 font-ui text-base">
          <a
            href={withBase("/posts/")}
            class="rounded-lg border border-border bg-surface/90 p-3 no-underline transition-colors hover:border-accent"
          >
            <div class="text-2xl font-medium text-accent">
              {sortedPosts.length}
            </div>
            <div class="mt-1 text-muted-foreground">文章</div>
          </a>
          <a
            href={withBase("/tags/")}
            class="rounded-lg border border-border bg-surface/90 p-3 no-underline transition-colors hover:border-accent"
          >
            <div class="text-2xl font-medium text-accent-secondary">
              {tags.length}
            </div>
            <div class="mt-1 text-muted-foreground">标签</div>
          </a>
          <a
            href={withBase("#featured")}
            class="rounded-lg border border-border bg-surface/90 p-3 no-underline transition-colors hover:border-accent"
          >
            <div class="text-2xl font-medium text-accent-tertiary">
              {featuredPosts.length}
            </div>
            <div class="mt-1 text-muted-foreground">精选</div>
          </a>
        </div>
      </aside>
    </section>

    <section
      class="grid gap-6 section-rule py-8 font-ui text-base text-muted-foreground sm:grid-cols-3"
    >
      <div>
        <p class="font-medium text-foreground">最新</p>
        <p class="mt-1">{latestPost?.data.title}</p>
      </div>
      <div>
        <p class="font-medium text-foreground">底层</p>
        <p class="mt-1">Astro 6 / Tailwind CSS 4 / React 19 / shadcn</p>
      </div>
      <div>
        <p class="font-medium text-foreground">原则</p>
        <p class="mt-1">静态优先，少即是多；让文字先抵达，再让界面退后。</p>
      </div>
    </section>

    <FontRoleSystem />

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "section-rule py-14",
            { "border-b border-border": recentPosts.length > 0 },
          ]}
        >
          <div class="mb-5 flex items-end justify-between gap-6">
            <div>
              <p class="font-ui text-sm font-medium text-accent">精选</p>
              <h2 class="mt-2 font-heading text-4xl leading-tight font-medium">
                精选文章
              </h2>
            </div>
          </div>
          <ul>
            {featuredPosts.slice(0, 3).map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="section-rule py-14">
          <div class="mb-5 flex items-end justify-between gap-6">
            <div>
              <p class="font-ui text-sm font-medium text-accent">近作</p>
              <h2 class="mt-2 font-heading text-4xl leading-tight font-medium">
                最新笔记
              </h2>
            </div>
            <a
              href={withBase("/posts/")}
              class="hidden items-center gap-1 font-ui text-sm font-medium text-accent no-underline hover:text-accent-secondary sm:flex"
            >
              全部文章
              <IconArrowRight class="size-4 rtl:-rotate-180" />
            </a>
          </div>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <ContentShowcase />

    <div class="section-rule py-10 text-center">
      <a
        href={withBase("/posts/")}
        class="inline-flex items-center gap-2 rounded-lg border border-border bg-primary px-4 py-2.5 font-ui text-sm font-medium text-primary-foreground no-underline shadow-sm transition-colors hover:bg-primary/90"
      >
        全部文章
        <IconArrowRight class="size-4 rtl:-rotate-180" />
      </a>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
