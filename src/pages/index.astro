---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import ContentShowcase from "@/components/ContentShowcase.astro";
import FontRoleSystem from "@/components/FontRoleSystem.astro";
import ReadingActions from "@/components/react/ReadingActions";
import getSortedPosts from "@/utils/getSortedPosts";
import getUniqueTags from "@/utils/getUniqueTags";
import { getPath } from "@/utils/getPath";
import { withBase } from "@/utils/basePath";
import getReadingTime from "@/utils/readingTime";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const tags = getUniqueTags(posts);
const latestPost = sortedPosts[0];
const latestReadingTime = latestPost ? getReadingTime(latestPost.body) : null;
const dateFormatter = new Intl.DateTimeFormat("zh-CN", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
  timeZone: SITE.timezone,
});
const systemHighlights = [
  {
    label: "Static core",
    value: "Astro 6",
    detail:
      "Content builds to flat pages, RSS, sitemap, Pagefind, and dynamic OG assets.",
  },
  {
    label: "Reading surface",
    value: "Charter / WenKai",
    detail:
      "English, Chinese, UI, code, and brand glyphs each have a bounded role.",
  },
  {
    label: "Interaction budget",
    value: "Islands only",
    detail: "React stays limited to controls that earn runtime cost.",
  },
] as const;

const craftNotes = [
  "Warm paper canvas with ink-blue emphasis instead of decorative gradients.",
  "Article cards expose date, reading time, tags, and title hierarchy at scan speed.",
  "CSS motion is progressive and reduced-motion aware, with static pages as the fallback.",
] as const;
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section
      id="hero"
      class="grid gap-10 py-10 sm:py-14 lg:grid-cols-[1.02fr_0.98fr] lg:items-center"
    >
      <div data-entrance="1">
        <p class="font-ui text-sm font-medium text-accent">
          落文 · <span lang="zh-Latn-pinyin">luò wén</span>
        </p>
        <h1
          class="mt-4 max-w-4xl font-display text-5xl leading-[1.05] font-medium text-balance text-foreground sm:text-7xl lg:text-8xl"
        >
          灯下有录，纸上有风。
        </h1>
        <p class="mt-6 max-w-2xl text-xl leading-9 text-muted-foreground">
          一处写设计、代码与系统判断的个人研究室。页面要像一张好纸，
          信息要能被快速扫描，长文要能经得住夜里的第二遍阅读。
        </p>
        <div
          class="mt-8 grid gap-4 border-s border-accent-ink ps-5 sm:max-w-2xl sm:grid-cols-[auto_1fr]"
          aria-label="Author signature"
        >
          <p
            class="font-heading text-4xl leading-none font-medium text-foreground sm:text-5xl"
          >
            Winston
          </p>
          <p
            class="font-role-quote text-3xl leading-tight text-accent sm:text-4xl"
          >
            纸中留白，夜里成篇
          </p>
        </div>
        <div class="mt-8">
          <ReadingActions />
        </div>
      </div>

      <aside class="relative" data-entrance="2">
        <figure class="liuyun-scroll">
          <div class="liuyun-scroll-media">
            <img
              src={withBase("/paper-visual.svg")}
              alt="流云、栖木、小舟和灯影组成的纸面视觉标记"
              class="liuyun-scroll-image"
              width="760"
              height="902"
              loading="eager"
              fetchpriority="high"
            />
          </div>
          <figcaption class="liuyun-scroll-caption">
            <span class="liuyun-scroll-hairline" aria-hidden="true"></span>
            <p>
              桨声灯影，
              <span>流云栖木。</span>
            </p>
          </figcaption>
        </figure>
      </aside>
    </section>

    <section class="grid gap-5 section-rule py-8 sm:grid-cols-3">
      <a
        href={withBase("/posts/")}
        class="metric-tile no-underline"
        aria-label={`阅读 ${sortedPosts.length} 篇文章`}
      >
        <span class="metric-value">{sortedPosts.length}</span>
        <span class="metric-label">published notes</span>
      </a>
      <a
        href={withBase("/tags/")}
        class="metric-tile no-underline"
        aria-label={`浏览 ${tags.length} 个标签`}
      >
        <span class="metric-value">{tags.length}</span>
        <span class="metric-label">working tags</span>
      </a>
      <a
        href={withBase("#featured")}
        class="metric-tile no-underline"
        aria-label={`查看 ${featuredPosts.length} 篇精选文章`}
      >
        <span class="metric-value">{featuredPosts.length}</span>
        <span class="metric-label">featured essays</span>
      </a>
    </section>

    {
      latestPost && latestReadingTime && (
        <section class="grid gap-8 section-rule py-12 lg:grid-cols-[0.78fr_1.22fr]">
          <div class="scroll-reveal">
            <p class="font-ui text-sm font-medium text-accent">Current issue</p>
            <h2 class="mt-3 max-w-md font-heading text-4xl leading-tight font-medium text-balance">
              先读最近一篇，再进归档
            </h2>
            <p class="mt-4 max-w-md text-base leading-7 text-muted-foreground">
              首页不做营销页。最新文章、精选文章、标签和搜索入口都放在第一层，
              读者可以直接进入内容，而不是穿过装饰。
            </p>
          </div>
          <a
            href={withBase(getPath(latestPost.id, latestPost.filePath))}
            class="latest-dispatch scroll-reveal no-underline"
          >
            <div class="flex flex-wrap items-center gap-2 font-ui text-sm text-muted-foreground">
              <span>{dateFormatter.format(latestPost.data.pubDatetime)}</span>
              <span aria-hidden="true" class="text-border">
                /
              </span>
              <span class="tabular-nums">{latestReadingTime.label}阅读</span>
            </div>
            <h3 class="mt-4 font-heading text-4xl leading-tight font-medium text-balance">
              {latestPost.data.title}
            </h3>
            <p class="mt-4 max-w-2xl text-lg leading-8 text-muted-foreground">
              {latestPost.data.description}
            </p>
            <span class="mt-6 inline-flex items-center gap-2 font-ui text-sm font-medium text-accent">
              进入文章
              <IconArrowRight
                class="size-4 rtl:-rotate-180"
                aria-hidden="true"
              />
            </span>
          </a>
        </section>
      )
    }

    <section class="grid gap-8 section-rule py-12 lg:grid-cols-[0.75fr_1.25fr]">
      <div class="scroll-reveal">
        <p class="font-ui text-sm font-medium text-accent">System map</p>
        <h2
          class="mt-3 max-w-lg font-heading text-4xl leading-tight font-medium text-balance"
        >
          一个博客应该先可靠，再漂亮
        </h2>
      </div>
      <div class="grid gap-4 sm:grid-cols-3">
        {
          systemHighlights.map(item => (
            <article class="system-tile scroll-reveal">
              <p class="font-ui text-sm text-muted-foreground">{item.label}</p>
              <h3 class="mt-3 font-heading text-2xl font-medium">
                {item.value}
              </h3>
              <p class="mt-3 font-ui text-base leading-7 text-muted-foreground">
                {item.detail}
              </p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="grid gap-8 section-rule py-12 lg:grid-cols-[1.08fr_0.92fr]">
      <div class="scroll-reveal">
        <p class="font-ui text-sm font-medium text-accent">Design contract</p>
        <h2
          class="mt-3 font-heading text-4xl leading-tight font-medium text-balance"
        >
          美学不是装饰层，而是维护规则
        </h2>
        <div class="mt-6 grid gap-3">
          {
            craftNotes.map(note => (
              <p class="craft-note font-ui text-base leading-7">{note}</p>
            ))
          }
        </div>
      </div>
      <div
        class="scroll-reveal rounded-lg border border-border bg-surface/90 p-5"
      >
        <p class="font-ui text-sm font-medium text-muted-foreground">
          Active tags
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          {
            tags.slice(0, 8).map(({ tag, tagName }) => (
              <a
                href={withBase(`/tags/${tag}/`)}
                class="rounded-sm border border-border bg-accent-quiet px-2.5 py-1.5 font-ui text-sm text-accent no-underline transition-colors hover:border-accent"
              >
                {tagName}
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <FontRoleSystem />

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "section-rule py-14",
            { "border-b border-border": recentPosts.length > 0 },
          ]}
        >
          <div class="mb-5 flex items-end justify-between gap-6">
            <div>
              <p class="font-ui text-sm font-medium text-accent">精选</p>
              <h2 class="mt-2 font-heading text-4xl leading-tight font-medium">
                精选文章
              </h2>
            </div>
          </div>
          <ul>
            {featuredPosts.slice(0, 3).map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="section-rule py-14">
          <div class="mb-5 flex items-end justify-between gap-6">
            <div>
              <p class="font-ui text-sm font-medium text-accent">近作</p>
              <h2 class="mt-2 font-heading text-4xl leading-tight font-medium">
                最新笔记
              </h2>
            </div>
            <a
              href={withBase("/posts/")}
              class="hidden items-center gap-1 font-ui text-sm font-medium text-accent no-underline hover:text-accent-secondary sm:flex"
            >
              全部文章
              <IconArrowRight
                class="size-4 rtl:-rotate-180"
                aria-hidden="true"
              />
            </a>
          </div>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <ContentShowcase />

    <div class="section-rule py-10 text-center">
      <a
        href={withBase("/posts/")}
        class="inline-flex items-center gap-2 rounded-lg border border-border bg-primary px-4 py-2.5 font-ui text-sm font-medium text-primary-foreground no-underline shadow-sm transition-colors hover:bg-primary/90"
      >
        全部文章
        <IconArrowRight class="size-4 rtl:-rotate-180" aria-hidden="true" />
      </a>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
