---
import { PUBLIC_ANALYTICS_ENDPOINT } from "astro:env/client";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";

const analyticsEndpoint = PUBLIC_ANALYTICS_ENDPOINT?.trim().replace(/\/+$/, "");
---

<Layout title={`访问统计 | ${SITE.title}`} noindex analytics={false}>
  <Header />
  <main
    id="main-content"
    class="analytics-shell app-layout py-10"
    data-analytics-dashboard
    data-endpoint={analyticsEndpoint}
  >
    <section class="analytics-hero">
      <div class="analytics-copy">
        <p class="analytics-overline">Analytics</p>
        <h1
          class="mt-3 max-w-xl font-heading text-5xl leading-tight font-medium text-balance"
        >
          访问统计
        </h1>
        <p class="analytics-intro">
          页面访问、独立访客、来源、地区、设备与最近访问记录。
        </p>
      </div>

      <form
        class="analytics-controls"
        data-analytics-controls
        autocomplete="off"
      >
        <label>
          <span>Endpoint</span>
          <input
            name="endpoint"
            type="url"
            inputmode="url"
            placeholder="https://luowen-analytics.example.workers.dev"
            value={analyticsEndpoint}
          />
        </label>
        <label>
          <span>Admin token</span>
          <input
            name="token"
            type="password"
            autocomplete="current-password"
            placeholder="Bearer token"
          />
        </label>
        <label>
          <span>Range</span>
          <select name="days">
            <option value="7">7 天</option>
            <option value="30" selected>30 天</option>
            <option value="90">90 天</option>
            <option value="365">365 天</option>
          </select>
        </label>
        <div class="analytics-actions">
          <button type="submit">刷新</button>
          <a data-export-link href="#" aria-disabled="true">导出 CSV</a>
        </div>
      </form>
    </section>

    <section class="analytics-metrics" aria-label="访问统计摘要">
      {
        [
          ["pageviews", "访问量", "Pageviews"],
          ["visitors", "访客", "Visitors"],
          ["sessions", "会话", "Sessions"],
        ].map(([metric, label, caption]) => (
          <article class="metric-card">
            <p>{label}</p>
            <strong data-metric={metric}>-</strong>
            <span>{caption}</span>
          </article>
        ))
      }
    </section>

    <p class="analytics-status" data-status>
      输入 endpoint 和 admin token 后刷新。
    </p>

    <section class="analytics-grid mt-8">
      <article class="analytics-panel analytics-panel-wide">
        <div class="panel-heading">
          <h2>时间线</h2>
          <span data-generated-at></span>
        </div>
        <div class="timeline-bars" data-timeline></div>
      </article>

      <article class="analytics-panel">
        <div class="panel-heading">
          <h2>访问时段</h2>
        </div>
        <div class="hour-bars" data-hourly></div>
      </article>

      <article class="analytics-panel">
        <div class="panel-heading">
          <h2>热门页面</h2>
        </div>
        <div data-table="topPages"></div>
      </article>

      <article class="analytics-panel">
        <div class="panel-heading">
          <h2>国家 / 地区</h2>
        </div>
        <div data-table="topCountries"></div>
      </article>

      <article class="analytics-panel">
        <div class="panel-heading">
          <h2>省市</h2>
        </div>
        <div data-table="topCities"></div>
      </article>

      <article class="analytics-panel">
        <div class="panel-heading">
          <h2>来源</h2>
        </div>
        <div data-table="topReferrers"></div>
      </article>

      <article class="analytics-panel">
        <div class="panel-heading">
          <h2>设备</h2>
        </div>
        <div data-table="devices"></div>
      </article>

      <article class="analytics-panel">
        <div class="panel-heading">
          <h2>浏览器</h2>
        </div>
        <div data-table="browsers"></div>
      </article>

      <article class="analytics-panel analytics-panel-wide">
        <div class="panel-heading">
          <h2>最近访问</h2>
        </div>
        <div class="recent-table" data-recent></div>
      </article>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  type StatusTone = "muted" | "error" | "success";
  type AnalyticsValue = string | number | null | undefined;
  type AnalyticsRow = Record<string, AnalyticsValue>;
  type SavedConfig = {
    endpoint?: string;
    token?: string;
    days?: string;
  };
  type AnalyticsData = {
    generatedAt: string;
    totals?: {
      pageviews?: number;
      visitors?: number;
      sessions?: number;
    };
    timeline?: AnalyticsRow[];
    hourly?: AnalyticsRow[];
    topPages?: AnalyticsRow[];
    topCountries?: AnalyticsRow[];
    topCities?: AnalyticsRow[];
    topReferrers?: AnalyticsRow[];
    devices?: AnalyticsRow[];
    browsers?: AnalyticsRow[];
    recentVisits?: AnalyticsRow[];
  };

  const root = document.querySelector<HTMLElement>(
    "[data-analytics-dashboard]"
  );
  const controls = document.querySelector<HTMLFormElement>(
    "[data-analytics-controls]"
  );
  const status = document.querySelector<HTMLElement>("[data-status]");
  const exportLink =
    document.querySelector<HTMLAnchorElement>("[data-export-link]");
  const generatedAt = document.querySelector<HTMLElement>(
    "[data-generated-at]"
  );
  const endpointInput = controls?.elements.namedItem(
    "endpoint"
  ) as HTMLInputElement | null;
  const tokenInput = controls?.elements.namedItem(
    "token"
  ) as HTMLInputElement | null;
  const daysSelect = controls?.elements.namedItem(
    "days"
  ) as HTMLSelectElement | null;
  const storageKey = "luowen:analytics-admin";

  function setStatus(message: string, tone: StatusTone = "muted") {
    if (!status) return;
    status.textContent = message;
    status.dataset.tone = tone;
  }

  function readSaved(): SavedConfig {
    try {
      const saved = JSON.parse(
        localStorage.getItem(storageKey) || "{}"
      ) as SavedConfig;
      return {
        ...saved,
        token: sessionStorage.getItem(`${storageKey}:token`) || "",
      };
    } catch {
      return {
        token: sessionStorage.getItem(`${storageKey}:token`) || "",
      };
    }
  }

  function saveConfig(endpoint: string, token: string, days: string) {
    try {
      localStorage.setItem(storageKey, JSON.stringify({ endpoint, days }));
    } catch {
      sessionStorage.setItem(storageKey, JSON.stringify({ endpoint, days }));
    }
    sessionStorage.setItem(`${storageKey}:token`, token);
  }

  function normalizeEndpoint(endpoint: string) {
    return endpoint.trim().replace(/\/+$/, "");
  }

  function apiUrl(
    endpoint: string,
    path: string,
    params: Record<string, string | number> = {}
  ) {
    const url = new URL(`${normalizeEndpoint(endpoint)}${path}`);
    Object.entries(params).forEach(([key, value]) => {
      url.searchParams.set(key, String(value));
    });
    return url.href;
  }

  function number(value: AnalyticsValue) {
    const parsed = Number(value || 0);
    return new Intl.NumberFormat("zh-CN").format(
      Number.isFinite(parsed) ? parsed : 0
    );
  }

  function safeText(value: unknown) {
    return value == null || value === "" || value === "Unknown"
      ? "未知"
      : String(value);
  }

  function escapeHtml(value: unknown) {
    return safeText(value).replace(/[&<>"']/g, char => {
      if (char === "&") return "&amp;";
      if (char === "<") return "&lt;";
      if (char === ">") return "&gt;";
      if (char === '"') return "&quot;";
      return "&#39;";
    });
  }

  function renderMetric(name: string, value: AnalyticsValue) {
    const target = document.querySelector(`[data-metric="${name}"]`);
    if (target) target.textContent = number(value);
  }

  function renderBars(
    target: Element | null,
    rows: AnalyticsRow[] | undefined,
    labelKey: string
  ) {
    if (!target) return;
    if (!rows?.length) {
      target.innerHTML = `<p class="empty-state">暂无数据</p>`;
      return;
    }

    const max = Math.max(...rows.map(row => Number(row.pageviews || 0)), 1);
    target.innerHTML = rows
      .map(row => {
        const pageviews = Number(row.pageviews || 0);
        const width = Math.max((pageviews / max) * 100, 3);
        const rawLabel = safeText(row[labelKey]);
        const label =
          labelKey === "hour" && rawLabel !== "未知"
            ? `${rawLabel.padStart(2, "0")}:00`
            : rawLabel;
        const escapedLabel = escapeHtml(label);
        return `
          <div class="analytics-bar-row">
            <span class="analytics-bar-label" title="${escapedLabel}">${escapedLabel}</span>
            <span class="analytics-bar-track" aria-hidden="true"><i style="width: ${width}%"></i></span>
            <strong class="analytics-bar-value">${number(pageviews)}</strong>
          </div>
        `;
      })
      .join("");
  }

  function renderTable(
    name: string,
    rows: AnalyticsRow[] | undefined,
    labelKey = "label"
  ) {
    const target = document.querySelector(`[data-table="${name}"]`);
    if (!target) return;
    if (!rows?.length) {
      target.innerHTML = `<p class="empty-state">暂无数据</p>`;
      return;
    }

    const max = Math.max(...rows.map(row => Number(row.pageviews || 0)), 1);
    target.innerHTML = `
      <div class="analytics-table-frame">
      <table class="analytics-table">
        <thead>
          <tr>
            <th>名称</th>
            <th>访问</th>
            <th>访客</th>
          </tr>
        </thead>
        <tbody>
          ${rows
            .map(row => {
              const pageviews = Number(row.pageviews || 0);
              const width = Math.max((pageviews / max) * 100, 4);
              const label = escapeHtml(row[labelKey]);
              return `
                <tr>
                  <td class="analytics-name-cell" title="${label}">
                    <span>${label}</span>
                    <i style="width: ${width}%"></i>
                  </td>
                  <td class="analytics-number">${number(pageviews)}</td>
                  <td>${number(row.visitors)}</td>
                </tr>
              `;
            })
            .join("")}
        </tbody>
      </table>
      </div>
    `;
  }

  function renderRecent(rows: AnalyticsRow[] | undefined) {
    const target = document.querySelector("[data-recent]");
    if (!target) return;
    if (!rows?.length) {
      target.innerHTML = `<p class="empty-state">暂无数据</p>`;
      return;
    }

    target.innerHTML = `
      <div class="analytics-table-frame">
      <table class="analytics-table analytics-table-recent">
        <thead>
          <tr>
            <th>时间</th>
            <th>页面</th>
            <th>地区</th>
            <th>IP</th>
            <th>设备</th>
          </tr>
        </thead>
        <tbody>
          ${rows
            .map(row => {
              const time = new Date(safeText(row.received_at)).toLocaleString(
                "zh-CN",
                { hour12: false }
              );
              const place = [row.country, row.region, row.city]
                .filter(Boolean)
                .map(safeText)
                .join(" / ");
              const ip = row.ip_address || `hash:${safeText(row.ip_hash)}`;
              const device = [row.device, row.browser]
                .filter(Boolean)
                .map(safeText)
                .join(" / ");
              return `
                <tr>
                  <td data-label="时间">${escapeHtml(time)}</td>
                  <td data-label="页面" title="${escapeHtml(row.path)}">${escapeHtml(row.path)}</td>
                  <td data-label="地区">${escapeHtml(place || "未知")}</td>
                  <td data-label="IP"><span class="analytics-chip">${escapeHtml(ip)}</span></td>
                  <td data-label="设备">${escapeHtml(device || "未知")}</td>
                </tr>
              `;
            })
            .join("")}
        </tbody>
      </table>
      </div>
    `;
  }

  async function loadAnalytics(
    endpoint: string,
    token: string,
    days: string
  ): Promise<AnalyticsData> {
    const summaryUrl = apiUrl(endpoint, "/summary", { days, limit: 20 });
    const response = await fetch(summaryUrl, {
      headers: { Authorization: `Bearer ${token}` },
    });

    if (!response.ok) {
      throw new Error(
        response.status === 401 ? "unauthorized" : "request_failed"
      );
    }

    return response.json() as Promise<AnalyticsData>;
  }

  function render(
    data: AnalyticsData,
    endpoint: string,
    token: string,
    days: string
  ) {
    renderMetric("pageviews", data.totals?.pageviews);
    renderMetric("visitors", data.totals?.visitors);
    renderMetric("sessions", data.totals?.sessions);
    renderBars(document.querySelector("[data-timeline]"), data.timeline, "day");
    renderBars(document.querySelector("[data-hourly]"), data.hourly, "hour");
    renderTable("topPages", data.topPages, "path");
    renderTable("topCountries", data.topCountries);
    renderTable("topCities", data.topCities);
    renderTable("topReferrers", data.topReferrers);
    renderTable("devices", data.devices);
    renderTable("browsers", data.browsers);
    renderRecent(data.recentVisits);

    if (generatedAt) {
      generatedAt.textContent = new Date(data.generatedAt).toLocaleString(
        "zh-CN",
        { hour12: false }
      );
    }

    if (exportLink) {
      exportLink.href = apiUrl(endpoint, "/export.csv", { days, limit: 1000 });
      exportLink.setAttribute("aria-disabled", "false");
      exportLink.onclick = event => {
        event.preventDefault();
        fetch(exportLink.href, {
          headers: { Authorization: `Bearer ${token}` },
        })
          .then(response => {
            if (!response.ok) throw new Error("export_failed");
            return response.blob();
          })
          .then(blob => {
            const url = URL.createObjectURL(blob);
            const anchor = document.createElement("a");
            anchor.href = url;
            anchor.download = `luowen-analytics-${days}d.csv`;
            anchor.click();
            URL.revokeObjectURL(url);
          })
          .catch(() => setStatus("导出失败，请检查 token。", "error"));
      };
    }
  }

  function hydrateForm() {
    if (!controls || !endpointInput || !tokenInput || !daysSelect) return;
    const saved = readSaved();
    const endpoint = normalizeEndpoint(
      root?.dataset.endpoint || saved.endpoint || ""
    );
    const token = saved.token || "";
    const days = saved.days || "30";

    endpointInput.value = endpoint;
    tokenInput.value = token;
    daysSelect.value = days;

    if (endpoint && token) {
      controls.requestSubmit();
    }
  }

  controls?.addEventListener("submit", async event => {
    event.preventDefault();
    if (!endpointInput || !tokenInput || !daysSelect) return;

    const endpoint = normalizeEndpoint(endpointInput.value);
    const token = tokenInput.value.trim();
    const days = daysSelect.value;

    if (!endpoint || !token) {
      setStatus("缺少 endpoint 或 admin token。", "error");
      return;
    }

    saveConfig(endpoint, token, days);
    setStatus("正在读取统计数据...");

    try {
      const data = await loadAnalytics(endpoint, token, days);
      render(data, endpoint, token, days);
      setStatus(`已加载最近 ${days} 天数据。`, "success");
    } catch (error) {
      const message = error instanceof Error ? error.message : "";
      setStatus(
        message === "unauthorized"
          ? "鉴权失败，请检查 admin token。"
          : "请求失败，请检查 endpoint、CORS 和 Worker 状态。",
        "error"
      );
    }
  });

  hydrateForm();
</script>

<style>
  .analytics-shell {
    --analytics-panel: color-mix(in oklab, var(--surface) 96%, transparent);
    --analytics-panel-soft: color-mix(
      in oklab,
      var(--surface) 82%,
      var(--background)
    );
    --analytics-line: color-mix(in oklab, var(--border) 84%, transparent);
    --analytics-subtle: color-mix(in oklab, var(--muted) 54%, transparent);
    --analytics-shadow:
      0 1px 0 color-mix(in oklab, var(--border) 72%, transparent),
      0 18px 48px color-mix(in oklab, var(--accent) 5%, transparent);
  }

  .analytics-hero {
    display: grid;
    grid-template-columns: minmax(0, 0.72fr) minmax(22rem, 1.28fr);
    gap: clamp(1rem, 3vw, 2rem);
    align-items: end;
  }

  .analytics-copy {
    min-width: 0;
  }

  .analytics-overline {
    color: var(--accent);
    font-family: var(--font-code);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .analytics-intro {
    margin-top: 1rem;
    max-width: 28rem;
    color: var(--muted-foreground);
    font-size: 1rem;
    line-height: 1.75;
  }

  .analytics-controls,
  .analytics-panel,
  .metric-card {
    border: 1px solid var(--analytics-line);
    border-radius: var(--radius);
    background: var(--analytics-panel);
    box-shadow: var(--analytics-shadow);
  }

  .analytics-controls {
    display: grid;
    grid-template-columns:
      minmax(12rem, 1.3fr) minmax(10rem, 1fr) minmax(7rem, 0.48fr)
      auto;
    gap: 0.85rem;
    align-items: end;
    padding: 1rem;
    font-family: var(--font-code);
  }

  .analytics-controls label {
    display: grid;
    gap: 0.42rem;
    min-width: 0;
  }

  .analytics-controls span,
  .metric-card p,
  .metric-card span,
  .panel-heading span,
  .analytics-status {
    color: var(--muted-foreground);
    font-family: var(--font-code);
    font-size: 0.78rem;
    letter-spacing: 0;
  }

  .analytics-controls input,
  .analytics-controls select {
    width: 100%;
    min-height: 2.75rem;
    border: 1px solid var(--analytics-line);
    border-radius: calc(var(--radius) * 0.7);
    background: color-mix(in oklab, var(--background) 82%, var(--surface));
    color: var(--foreground);
    padding: 0.58rem 0.72rem;
    font-size: 0.9rem;
    font-variant-numeric: tabular-nums;
    outline: none;
    transition:
      border-color 160ms ease,
      box-shadow 160ms ease,
      background-color 160ms ease;
  }

  .analytics-controls input:focus,
  .analytics-controls select:focus {
    border-color: color-mix(in oklab, var(--accent) 54%, var(--border));
    box-shadow: 0 0 0 3px color-mix(in oklab, var(--accent) 13%, transparent);
  }

  .analytics-controls button,
  .analytics-controls a {
    display: inline-flex;
    min-height: 2.75rem;
    align-items: center;
    justify-content: center;
    border: 1px solid color-mix(in oklab, var(--accent) 24%, var(--border));
    border-radius: calc(var(--radius) * 0.7);
    padding: 0.6rem 0.95rem;
    background: var(--primary);
    color: var(--primary-foreground);
    font-weight: 500;
    font-size: 0.9rem;
    text-decoration: none;
    white-space: nowrap;
    transition:
      transform 140ms ease,
      border-color 160ms ease,
      background-color 160ms ease;
  }

  .analytics-controls a {
    background: color-mix(in oklab, var(--surface) 90%, var(--accent-quiet));
    color: var(--accent);
  }

  .analytics-controls button:hover,
  .analytics-controls a:hover {
    transform: translateY(-1px);
    border-color: color-mix(in oklab, var(--accent) 46%, var(--border));
  }

  .analytics-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    align-items: end;
    justify-content: end;
  }

  .analytics-controls a[aria-disabled="true"] {
    opacity: 0.48;
    pointer-events: none;
  }

  .analytics-metrics {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.85rem;
    margin-top: 1.25rem;
  }

  .metric-card {
    position: relative;
    display: grid;
    min-height: 8.25rem;
    overflow: hidden;
    padding: 1rem 1rem 0.95rem;
  }

  .metric-card::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    width: 3px;
    background: color-mix(in oklab, var(--accent) 72%, transparent);
  }

  .metric-card p {
    align-self: start;
    color: var(--accent-tertiary);
  }

  .metric-card span {
    align-self: end;
    color: color-mix(in oklab, var(--muted-foreground) 78%, transparent);
  }

  .metric-card strong {
    display: block;
    align-self: center;
    color: var(--accent);
    font-family: var(--font-code);
    font-size: clamp(2.35rem, 6vw, 3.75rem);
    font-weight: 500;
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }

  .analytics-status {
    margin-top: 0.85rem;
    min-height: 1.5rem;
  }

  [data-status][data-tone="error"] {
    color: var(--slogan);
  }

  [data-status][data-tone="success"] {
    color: var(--accent);
  }

  .analytics-grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .analytics-panel {
    grid-column: span 6;
    min-width: 0;
    min-height: 12.5rem;
    padding: 1.05rem;
    overflow: hidden;
  }

  .analytics-panel-wide {
    grid-column: 1 / -1;
    min-height: 13rem;
  }

  .panel-heading {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.95rem;
    border-bottom: 1px solid var(--analytics-line);
    padding-bottom: 0.75rem;
  }

  .panel-heading h2 {
    font-family: var(--font-heading);
    font-size: clamp(1.28rem, 3vw, 1.55rem);
    font-weight: 500;
    line-height: 1.2;
  }

  .timeline-bars,
  .hour-bars {
    display: grid;
    gap: 0.62rem;
  }

  :global(.analytics-bar-row) {
    display: grid;
    grid-template-columns: minmax(5.6rem, 9rem) minmax(0, 1fr) minmax(
        3rem,
        4.5rem
      );
    gap: 0.85rem;
    align-items: center;
    min-height: 2rem;
    font-family: var(--font-code);
    font-size: 0.86rem;
    font-variant-numeric: tabular-nums;
  }

  :global(.analytics-bar-label) {
    min-width: 0;
    overflow: hidden;
    color: var(--foreground);
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  :global(.analytics-bar-track) {
    height: 0.55rem;
    overflow: hidden;
    border-radius: 999px;
    background: var(--analytics-subtle);
  }

  :global(.analytics-bar-track i) {
    display: block;
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(
      90deg,
      var(--accent),
      color-mix(in oklab, var(--accent-secondary) 86%, var(--accent))
    );
  }

  :global(.analytics-bar-value) {
    color: var(--accent);
    font-weight: 500;
    text-align: end;
