---
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@/utils/slugify";
import { getPath } from "@/utils/getPath";
import { withBase } from "@/utils/basePath";
import Datetime from "./Datetime.astro";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"blog">;

const { variant: Heading = "h2", id, data, filePath } = Astro.props;

const { title, description, tags, ...props } = data;
---

<li class="group border-b border-border/70 py-6 last:border-b-0">
  <article class="grid gap-3 sm:grid-cols-[1fr_auto] sm:items-start">
    <div>
      <a
        href={withBase(getPath(id, filePath))}
        class="inline-block text-foreground no-underline outline-offset-4 hover:text-accent"
      >
        <Heading
          class="font-heading text-3xl leading-tight font-medium text-balance transition-colors sm:text-4xl"
          style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
        >
          {title}
        </Heading>
      </a>
      <p class="mt-3 max-w-2xl text-lg leading-8 text-muted-foreground">
        {description}
      </p>
    </div>

    <div class="sm:pt-1 sm:text-end">
      <Datetime
        {...props}
        class="font-ui text-muted-foreground sm:justify-end"
      />
      <div class="mt-3 flex flex-wrap gap-2 sm:justify-end">
        {
          tags.slice(0, 3).map(tag => (
            <a
              href={withBase(`/tags/${slugifyStr(tag)}/`)}
              class="rounded-sm border border-border bg-accent-quiet px-2.5 py-1.5 font-ui text-sm text-accent no-underline transition-colors hover:border-accent"
            >
              {tag}
            </a>
          ))
        }
      </div>
    </div>
  </article>
</li>
