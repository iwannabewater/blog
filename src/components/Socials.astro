---
import { SOCIALS } from "@/constants";
import LinkButton from "./LinkButton.astro";
---

<div class="flex flex-wrap items-center justify-center gap-1.5 sm:justify-end">
  {
    SOCIALS.map(social => (
      <LinkButton
        href={social.href}
        class="rounded-md border border-border bg-surface p-2 text-muted-foreground no-underline shadow-sm transition-colors hover:border-accent/50 hover:text-accent sm:p-2"
        title={social.linkTitle}
        target={social.href.startsWith("http") ? "_blank" : undefined}
        rel={social.href.startsWith("http") ? "noopener noreferrer" : undefined}
      >
        <svg
          viewBox="0 0 24 24"
          aria-hidden="true"
          class="inline-block size-[1.125rem] fill-current opacity-90 transition-transform duration-200 group-hover:scale-105"
        >
          <path d={social.path} />
        </svg>
        <span class="sr-only">{social.linkTitle}</span>
      </LinkButton>
    ))
  }
</div>
