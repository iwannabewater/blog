---
import IconX from "@/assets/icons/IconX.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconArchive from "@/assets/icons/IconArchive.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconMenuDeep from "@/assets/icons/IconMenuDeep.svg";
import IconThemeSystem from "@/assets/icons/IconThemeSystem.svg";
import { Feather } from "lucide-react";
import LinkButton from "./LinkButton.astro";
import { SITE } from "@/config";
import { withBase, withoutBase } from "@/utils/basePath";

const { pathname } = Astro.url;

// Remove trailing slash from current pathname if exists
const currentPath =
  withoutBase(pathname).endsWith("/") && withoutBase(pathname) !== "/"
    ? withoutBase(pathname).slice(0, -1)
    : withoutBase(pathname);

const isActive = (path: string) => {
  const currentPathArray = currentPath.split("/").filter(p => p.trim());
  const pathArray = path.split("/").filter(p => p.trim());

  return currentPath === path || currentPathArray[0] === pathArray[0];
};
---

<a
  id="skip-to-content"
  href="#main-content"
  class="absolute start-16 -top-full z-50 rounded-md border border-border bg-surface px-3 py-2 font-ui text-sm text-accent shadow-sm backdrop-blur-lg transition-[top] focus:top-4"
>
  Skip to content
</a>

<header class="site-header sticky top-0 z-30">
  <div class="app-layout">
    <div
      id="top-nav-wrap"
      class="relative flex min-h-18 w-full items-center justify-between py-3"
    >
      <a
        href={withBase("/")}
        class="group flex min-w-0 items-center gap-3 py-1 no-underline"
      >
        <span aria-hidden="true" class="brand-mark">
          <Feather className="size-7 sm:size-8" strokeWidth={1.55} />
        </span>
        <span class="grid min-w-0 justify-items-center">
          <span
            class="font-role-brand block text-3xl leading-none text-foreground sm:text-4xl"
          >
            {SITE.title}
          </span>
          <span
            lang="zh-Latn-pinyin"
            class="font-role-slogan mt-1 block text-xl leading-none text-slogan"
          >
            luò wén
          </span>
        </span>
      </a>
      <nav id="nav-menu" class="flex items-center justify-end font-ui">
        <button
          id="menu-btn"
          class="focus-outline grid size-10 place-items-center rounded-lg border border-border bg-surface sm:hidden"
          aria-label="打开菜单"
          aria-expanded="false"
          aria-controls="menu-items"
        >
          <IconX id="close-icon" class="hidden" aria-hidden="true" />
          <IconMenuDeep id="menu-icon" aria-hidden="true" />
        </button>
        <ul
          id="menu-items"
          class:list={[
            "absolute end-0 top-14 grid w-64 grid-cols-2 gap-2 rounded-lg border border-border bg-surface p-2 shadow-lg",
            "[&>li>a]:block [&>li>a]:rounded-md [&>li>a]:px-3 [&>li>a]:py-2.5 [&>li>a]:text-center [&>li>a]:text-base [&>li>a]:font-medium [&>li>a]:no-underline [&>li>a]:hover:bg-muted [&>li>a]:hover:text-accent",
            "hidden",
            "sm:static sm:flex sm:w-auto sm:grid-cols-none sm:items-center sm:gap-1.5 sm:border-0 sm:bg-transparent sm:p-0 sm:shadow-none sm:[&>li>a]:grid sm:[&>li>a]:size-12 sm:[&>li>a]:place-items-center sm:[&>li>a]:px-0 sm:[&>li>a]:py-0 sm:[&>li>a]:text-xl",
          ]}
        >
          <li class="col-span-2">
            <a
              href={withBase("/posts")}
              class:list={{ "active-nav": isActive("/posts") }}
            >
              文章
            </a>
          </li>
          <li class="col-span-2">
            <a
              href={withBase("/tags")}
              class:list={{ "active-nav": isActive("/tags") }}
            >
              标签
            </a>
          </li>
          <li class="col-span-2">
            <a
              href={withBase("/about")}
              class:list={{ "active-nav": isActive("/about") }}
            >
              关于
            </a>
          </li>
          {
            SITE.showArchives && (
              <li class="col-span-2">
                <LinkButton
                  href={withBase("/archives")}
                  class:list={[
                    "focus-outline flex justify-center rounded-md p-3 sm:size-12 sm:items-center sm:p-0 [&>svg]:size-6",
                    {
                      "active-nav [&>svg]:stroke-accent": isActive("/archives"),
                    },
                  ]}
                  title="归档"
                  aria-label="归档"
                >
                  <IconArchive
                    class="hidden sm:inline-block"
                    aria-hidden="true"
                  />
                  <span class="sm:sr-only">归档</span>
                </LinkButton>
              </li>
            )
          }
          <li class="col-span-1 flex items-center justify-center">
            <LinkButton
              href={withBase("/search")}
              class:list={[
                "focus-outline flex rounded-md p-3 sm:size-12 sm:items-center sm:justify-center sm:p-0 [&>svg]:size-6",
                { "[&>svg]:stroke-accent": isActive("/search") },
              ]}
              title="搜索"
              aria-label="搜索"
            >
              <IconSearch aria-hidden="true" />
              <span class="sr-only">搜索</span>
            </LinkButton>
          </li>
          {
            SITE.lightAndDarkMode && (
              <li class="col-span-1 flex items-center justify-center">
                <button
                  id="theme-btn"
                  class="focus-outline relative size-12 rounded-md p-3 hover:bg-muted sm:size-12 sm:p-3 hover:[&>svg]:stroke-accent"
                  title="当前主题：跟随系统，点击切换"
                  aria-label="当前主题：跟随系统"
                  aria-live="polite"
                  data-theme-mode="system"
                >
                  <IconThemeSystem
                    class="theme-icon theme-icon-system"
                    aria-hidden="true"
                  />
                  <IconSunHigh
                    class="theme-icon theme-icon-light"
                    aria-hidden="true"
                  />
                  <IconMoon
                    class="theme-icon theme-icon-dark"
                    aria-hidden="true"
                  />
                </button>
              </li>
            )
          }
        </ul>
      </nav>
    </div>
  </div>
</header>

<script>
  function toggleNav() {
    const menuBtn = document.querySelector("#menu-btn");
    const menuItems = document.querySelector("#menu-items");
    const menuIcon = document.querySelector("#menu-icon");
    const closeIcon = document.querySelector("#close-icon");

    if (!menuBtn || !menuItems || !menuIcon || !closeIcon) return;

    menuBtn.addEventListener("click", () => {
      const openMenu = menuBtn.getAttribute("aria-expanded") === "true";

      menuBtn.setAttribute("aria-expanded", openMenu ? "false" : "true");
      menuBtn.setAttribute("aria-label", openMenu ? "打开菜单" : "关闭菜单");

      menuItems.classList.toggle("hidden");
      menuIcon.classList.toggle("hidden");
      closeIcon.classList.toggle("hidden");
    });
  }

  toggleNav();

  // Runs on view transitions navigation
  document.addEventListener("astro:after-swap", toggleNav);
</script>
