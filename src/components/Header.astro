---
import IconX from "@/assets/icons/IconX.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconArchive from "@/assets/icons/IconArchive.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconMenuDeep from "@/assets/icons/IconMenuDeep.svg";
import IconAtelierMark from "@/assets/icons/IconAtelierMark.svg";
import LinkButton from "./LinkButton.astro";
import { SITE } from "@/config";
import { withBase, withoutBase } from "@/utils/basePath";

const { pathname } = Astro.url;

// Remove trailing slash from current pathname if exists
const currentPath =
  withoutBase(pathname).endsWith("/") && withoutBase(pathname) !== "/"
    ? withoutBase(pathname).slice(0, -1)
    : withoutBase(pathname);

const isActive = (path: string) => {
  const currentPathArray = currentPath.split("/").filter(p => p.trim());
  const pathArray = path.split("/").filter(p => p.trim());

  return currentPath === path || currentPathArray[0] === pathArray[0];
};
---

<a
  id="skip-to-content"
  href="#main-content"
  class="absolute start-16 -top-full z-50 rounded-md border border-border bg-surface px-3 py-2 font-ui text-sm text-accent shadow-sm backdrop-blur-lg transition-all focus:top-4"
>
  Skip to content
</a>

<header
  class="sticky top-0 z-30 border-b border-border/75 bg-background/90 backdrop-blur-xl"
>
  <div class="app-layout">
    <div
      id="top-nav-wrap"
      class="relative flex min-h-18 w-full items-center justify-between py-3"
    >
      <a
        href={withBase("/")}
        class="group flex min-w-0 items-center gap-3 py-1 no-underline"
      >
        <span
          aria-hidden="true"
          class="grid size-10 shrink-0 place-items-center rounded-lg border border-border bg-surface text-accent shadow-sm transition-colors group-hover:border-accent/60 group-hover:text-accent-secondary"
        >
          <IconAtelierMark class="size-7" />
        </span>
        <span class="min-w-0">
          <span
            class="block font-heading text-xl leading-none font-semibold sm:text-2xl"
          >
            {SITE.title}
          </span>
          <span
            class="mt-1 hidden font-ui text-xs text-muted-foreground sm:block"
          >
            Design / Code / Systems
          </span>
        </span>
      </a>
      <nav id="nav-menu" class="flex items-center justify-end font-ui">
        <button
          id="menu-btn"
          class="focus-outline grid size-10 place-items-center rounded-lg border border-border bg-surface sm:hidden"
          aria-label="Open Menu"
          aria-expanded="false"
          aria-controls="menu-items"
        >
          <IconX id="close-icon" class="hidden" />
          <IconMenuDeep id="menu-icon" />
        </button>
        <ul
          id="menu-items"
          class:list={[
            "absolute end-0 top-14 grid w-60 grid-cols-2 gap-2 rounded-lg border border-border bg-surface p-2 shadow-lg",
            "[&>li>a]:block [&>li>a]:rounded-md [&>li>a]:px-3 [&>li>a]:py-2.5 [&>li>a]:text-center [&>li>a]:text-sm [&>li>a]:font-medium [&>li>a]:no-underline [&>li>a]:hover:bg-muted [&>li>a]:hover:text-accent",
            "hidden",
            "sm:static sm:flex sm:w-auto sm:grid-cols-none sm:border-0 sm:bg-transparent sm:p-0 sm:shadow-none sm:[&>li>a]:px-2 sm:[&>li>a]:py-1",
          ]}
        >
          <li class="col-span-2">
            <a
              href={withBase("/posts")}
              class:list={{ "active-nav": isActive("/posts") }}
            >
              Posts
            </a>
          </li>
          <li class="col-span-2">
            <a
              href={withBase("/tags")}
              class:list={{ "active-nav": isActive("/tags") }}
            >
              Tags
            </a>
          </li>
          <li class="col-span-2">
            <a
              href={withBase("/about")}
              class:list={{ "active-nav": isActive("/about") }}
            >
              About
            </a>
          </li>
          {
            SITE.showArchives && (
              <li class="col-span-2">
                <LinkButton
                  href={withBase("/archives")}
                  class:list={[
                    "focus-outline flex justify-center rounded-md p-3 sm:p-1",
                    {
                      "active-nav [&>svg]:stroke-accent": isActive("/archives"),
                    },
                  ]}
                  title="Archives"
                  aria-label="archives"
                >
                  <IconArchive class="hidden sm:inline-block" />
                  <span class="sm:sr-only">Archives</span>
                </LinkButton>
              </li>
            )
          }
          <li class="col-span-1 flex items-center justify-center">
            <LinkButton
              href={withBase("/search")}
              class:list={[
                "focus-outline flex rounded-md p-3 sm:p-1",
                { "[&>svg]:stroke-accent": isActive("/search") },
              ]}
              title="Search"
              aria-label="search"
            >
              <IconSearch />
              <span class="sr-only">Search</span>
            </LinkButton>
          </li>
          {
            SITE.lightAndDarkMode && (
              <li class="col-span-1 flex items-center justify-center">
                <button
                  id="theme-btn"
                  class="focus-outline relative size-12 rounded-md p-4 hover:bg-muted sm:size-8 sm:p-1 hover:[&>svg]:stroke-accent"
                  title="Toggles light & dark"
                  aria-label="auto"
                  aria-live="polite"
                >
                  <IconMoon class="absolute top-[50%] left-[50%] -translate-[50%] scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
                  <IconSunHigh class="absolute top-[50%] left-[50%] -translate-[50%] scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
                </button>
              </li>
            )
          }
        </ul>
      </nav>
    </div>
  </div>
</header>

<script>
  function toggleNav() {
    const menuBtn = document.querySelector("#menu-btn");
    const menuItems = document.querySelector("#menu-items");
    const menuIcon = document.querySelector("#menu-icon");
    const closeIcon = document.querySelector("#close-icon");

    if (!menuBtn || !menuItems || !menuIcon || !closeIcon) return;

    menuBtn.addEventListener("click", () => {
      const openMenu = menuBtn.getAttribute("aria-expanded") === "true";

      menuBtn.setAttribute("aria-expanded", openMenu ? "false" : "true");
      menuBtn.setAttribute("aria-label", openMenu ? "Open Menu" : "Close Menu");

      menuItems.classList.toggle("hidden");
      menuIcon.classList.toggle("hidden");
      closeIcon.classList.toggle("hidden");
    });
  }

  toggleNav();

  // Runs on view transitions navigation
  document.addEventListener("astro:after-swap", toggleNav);
</script>
