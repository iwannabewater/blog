---
const components = [
  {
    label: "纸条",
    title: "策展式提示",
    body: "用于文章中的关键判断、方法边界和阅读提醒，保留信息密度但不打断正文。",
  },
  {
    label: "旁注",
    title: "边界说明",
    body: "给复杂段落补一层上下文，适合放假设、限制和实现取舍。",
  },
  {
    label: "Code",
    title: "工程片段",
    body: "代码块收敛为低饱和纸面高亮，保留复制按钮、文件名和语法层次。",
  },
];
---

<section class="section-rule py-14">
  <div class="grid gap-8 lg:grid-cols-[0.75fr_1.25fr]">
    <div>
      <p class="font-ui text-sm font-medium text-accent">纸面组件</p>
      <h2
        class="mt-3 font-heading text-4xl leading-tight font-medium text-balance"
      >
        组件像纸上的批注，不抢正文
      </h2>
      <p class="mt-4 max-w-md text-base leading-7 text-muted-foreground">
        保留 AstroPaper 的 Markdown 工作流，通过 Kami
        式纸面系统增强引用、代码、表格、提示框、旁注、键帽和高亮。
      </p>
    </div>

    <div class="grid gap-4">
      <article
        class="rounded-lg border border-border bg-surface/90 p-5 shadow-sm"
      >
        <div class="font-ui text-sm font-medium text-accent-secondary">
          {components[0].label}
        </div>
        <h3 class="mt-3 font-heading text-2xl font-medium">
          {components[0].title}
        </h3>
        <p class="mt-3 leading-7 text-muted-foreground">{components[0].body}</p>
      </article>

      <article
        class="aside-note rounded-lg border border-border bg-surface p-5 shadow-sm"
      >
        <div class="font-ui text-sm font-medium text-accent-secondary">
          {components[1].label}
        </div>
        <h3 class="mt-3 font-heading text-2xl font-medium">
          {components[1].title}
        </h3>
        <p class="mt-3 leading-7 text-muted-foreground">{components[1].body}</p>
      </article>

      <article
        class="overflow-hidden rounded-lg border border-border bg-surface/90 shadow-sm"
      >
        <div
          class="border-b border-border bg-muted/60 px-4 py-2 font-ui text-sm text-muted-foreground"
        >
          {components[2].label} / JetBrains Mono / src/lib/notes.ts
        </div>
        <pre
          class="m-0 overflow-x-auto p-4 font-code text-sm leading-6"><code><span class="text-accent">export const</span> <span class="text-accent-secondary">note</span> = {"{"}
  <span class="text-muted-foreground">tone</span>: <span class="text-slogan">"warm parchment"</span>,
  <span class="text-muted-foreground">stack</span>: [<span class="text-slogan">"Astro"</span>, <span class="text-slogan">"Tailwind CSS"</span>, <span class="text-slogan">"React"</span>, <span class="text-slogan">"shadcn/ui"</span>],
{"};"}</code></pre>
      </article>
    </div>
  </div>
</section>
