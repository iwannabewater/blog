---
const roles = [
  {
    role: "Brand",
    cn: "左上标题",
    fonts: "YRDZST-Regular + LXGW WenKai",
    detail: "杨任东竹石体只用于“落文”品牌字，保留手写锋芒，不进入正文。",
    sample: "落文",
    demoClass: "font-role-brand text-5xl",
  },
  {
    role: "Display",
    cn: "封面与章题",
    fonts: "LXGW WenKai",
    detail: "中文封面、章题和短句都回到霞鹜文楷，减少下载和视觉切换。",
    sample: "流云栖木",
    demoClass: "font-role-display text-4xl font-medium",
  },
  {
    role: "Heading",
    cn: "英文标题与混排标题",
    fonts: "Charter + LXGW WenKai",
    detail: "英文先走 Charter，中文直接回到霞鹜文楷，混排时保持书页感。",
    sample: "Quiet Systems / 纸页",
    demoClass: "font-role-heading text-3xl font-medium",
  },
  {
    role: "Body",
    cn: "正文主力",
    fonts: "Charter + LXGW WenKai",
    detail: "英文正文保持 Charter 的书籍质感，中文长段落交给霞鹜文楷。",
    sample: "在速度之外，文字仍需留下呼吸。",
    demoClass: "font-role-body text-2xl",
  },
  {
    role: "Callout",
    cn: "引句与纸条",
    fonts: "Charter + LXGW WenKai",
    detail: "拉引句不再额外引入中文展示字体，用正文同源的字形保持安静。",
    sample: "灯下有录，纸上有风。",
    demoClass: "font-role-quote text-3xl font-medium",
  },
  {
    role: "UI",
    cn: "导航、标签、按钮",
    fonts: "Comic Neue + LXGW WenKai",
    detail: "Comic Neue 只负责界面小字，让操作区更松弛，不进入长文正文。",
    sample: "posts / tags / rss",
    demoClass: "font-role-ui text-lg font-medium",
  },
  {
    role: "Slogan",
    cn: "唯一英文手写标语",
    fonts: "Caveat",
    detail: "只用于 Larger than life 这一处，复刻手写题签的棕色墨迹。",
    sample: "Larger than life",
    demoClass: "font-role-slogan text-5xl text-slogan",
  },
  {
    role: "Code",
    cn: "代码与文件名",
    fonts: "JetBrains Mono + LXGW WenKai",
    detail: "代码区使用 JetBrains Mono，中文注释和缺字只回到霞鹜文楷。",
    sample: 'const note = "kami";',
    demoClass: "font-role-code text-base",
  },
];
---

<section class="section-rule py-14">
  <div class="grid gap-8 lg:grid-cols-[0.75fr_1.25fr]">
    <div>
      <p class="font-ui text-sm font-medium text-accent">字体角色</p>
      <h2
        class="mt-3 max-w-xl font-heading text-4xl leading-tight font-medium text-balance"
      >
        字体少而有序，分工必须清楚
      </h2>
      <p class="mt-4 max-w-md text-base leading-7 text-muted-foreground">
        品牌字只用杨任东竹石体，中文只保留霞鹜文楷，英文用 Charter 与 Comic Neue
        分工；手写标语只用 Caveat；代码交给 JetBrains Mono。
      </p>
    </div>

    <div class="grid gap-3 sm:grid-cols-2">
      {
        roles.map(role => (
          <article class="rounded-lg border border-border bg-surface/90 p-4 shadow-sm">
            <div class="flex items-start justify-between gap-4 font-ui text-sm text-muted-foreground">
              <div>
                <p class="font-medium text-foreground">{role.role}</p>
                <p class="mt-1">{role.cn}</p>
              </div>
              <p class="text-end text-accent-secondary">{role.fonts}</p>
            </div>
            <p
              class:list={[
                "mt-5 min-h-12 leading-tight text-foreground",
                role.demoClass,
              ]}
            >
              {role.sample}
            </p>
            <p class="mt-4 font-ui text-base leading-7 text-muted-foreground">
              {role.detail}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>
